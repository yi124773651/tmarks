# TMarks 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ============================================
# 前端环境变量（Vite）
# ============================================

# API 基础 URL（可选，默认为 /api/v1）
VITE_API_URL=/api/v1

# 跳过登录验证（仅开发环境，生产环境必须设为 false 或删除）
VITE_SKIP_AUTH=false

# ============================================
# Cloudflare 配置（本地开发参考）
# ============================================
# 注意：这些配置应该在 wrangler.toml 中配置

# Cloudflare Account ID
CLOUDFLARE_ACCOUNT_ID=your_account_id

# Cloudflare API Token
CLOUDFLARE_API_TOKEN=your_api_token

# D1 Database ID
D1_DATABASE_ID=your_database_id

# KV Namespace ID
KV_NAMESPACE_ID=your_kv_namespace_id

# ============================================
# 后端环境变量（Cloudflare Pages Functions）
# ============================================
# 注意：这些变量应该在 wrangler.toml 或 Cloudflare Dashboard 中配置

# JWT 密钥（生产环境必须使用 wrangler secret put）
# 生成方式: openssl rand -base64 32
# JWT_SECRET=your-super-secret-jwt-key-here

# JWT 过期时间
# JWT_ACCESS_TOKEN_EXPIRES_IN=365d
# JWT_REFRESH_TOKEN_EXPIRES_IN=365d

# 环境标识
# ENVIRONMENT=development

# ============================================
# 本地开发提示
# ============================================
#
# 1. 本地 D1 数据库初始化:
#    wrangler d1 migrations apply tmarks-db --local
#
# 2. 本地开发服务器:
#    pnpm run dev          # 前端
#    wrangler dev          # 后端（可选）
#
# 3. 查看本地数据库:
#    wrangler d1 execute tmarks-db --local --command "SELECT * FROM users"
#

# ============================================
# 生产环境配置提示
# ============================================
#
# 1. 配置 Secrets（敏感信息）:
#    wrangler secret put JWT_SECRET
#
# 2. 配置环境变量（非敏感信息）:
#    在 wrangler.toml 的 [vars] 部分配置
#
# 3. 数据库迁移:
#    wrangler d1 migrations apply tmarks-db --remote
#
# 4. 部署:
#    pnpm run build
#    wrangler deploy
#
